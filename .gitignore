!rtl/generated_real/_UT_RealNutShellCache.so
!rtl/generated_real/libUTRealNutShellCache.so
!rtl/generated/_UT_NutShellCache.so
!rtl/generated/libUTNutShellCache.so
!rtl/dut_gen/UT_NutShellCache/libUTNutShellCache.so

